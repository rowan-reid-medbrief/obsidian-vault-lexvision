      <data key="d58">claim:0020</data>
      <data key="d59">decision:0001</data>
      <data key="d60">0.75</data>
      <data key="d61">[{"quote": "Do you know what you've actually done now is you've solved another problem we have, which is duplicate detection in the sorting algorithm for Sally.", "ts": 1104.5, "source": "transcript"}, {"quote": "Much of the insights also only applies to sorted sets of records. So we can bundle it as a marketing thing.", "ts": 1230.5, "source": "transcript"}]</data>
    </edge>
