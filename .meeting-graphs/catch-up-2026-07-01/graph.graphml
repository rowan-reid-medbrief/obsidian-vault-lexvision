    <node id="chapter:02">
      <data key="d0">Chapter</data>
      <data key="d1">Screen share: synthetic PDF test harness walkthrough</data>
      <data key="d7">1.0</data>
      <data key="d8">[]</data>
      <data key="d9">["chapter:02"]</data>
      <data key="d45">2</data>
      <data key="d46">Rowan shares his screen and walks Deon through the synthetic PDF/records generator, the resorting tool (deletes, inserts, rearranges, splits pages), and the page-matching engine that tracks what happened to each page.</data>
      <data key="d47">150.0</data>
