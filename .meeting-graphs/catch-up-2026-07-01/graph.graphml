    <edge source="claim:0019" target="decision:0003" id="e-supports-0186">
      <data key="d57">SUPPORTS</data>
      <data key="d58">claim:0019</data>
      <data key="d59">decision:0003</data>
      <data key="d60">0.6</data>
      <data key="d61">[{"quote": "Like, the best we can possibly get is, like, three quarters of your annotations are placed back to where we're confident they are, and 25% of them you're going to need to replace.", "ts": 1083.2, "source": "transcript"}, {"quote": "So, redaction, my thinking, I might have mentioned this, is also that we do redaction inside DocSorter because they're the people who, the clinicians would be the people who are best placed to do the actual redaction in the first place.", "ts": 1387.0, "source": "transcript"}]</data>
    </edge>
    <edge source="claim:0020" target="topic:duplicate-detection-reuse" id="e-relates_to-0086">
      <data key="d57">RELATES_TO</data>
      <data key="d58">claim:0020</data>
      <data key="d59">topic:duplicate-detection-reuse</data>
      <data key="d60">0.9</data>
      <data key="d61">[{"quote": "you've solved another problem we have, which is duplicate detection in the sorting algorithm for Sally", "ts": "L257", "source": "chapter:05"}]</data>
    </edge>
