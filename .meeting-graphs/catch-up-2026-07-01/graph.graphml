      <data key="d58">person:rowan-reid</data>
      <data key="d59">claim:0009</data>
      <data key="d60">0.5</data>
      <data key="d61">[{"quote": "So what I've created here, you'll just see all of these PDFs appeared. So I've just kind of created, let me open it up. So, for example, this is the PDF. You can see there's a clean and degraded version of every PDF.", "ts": "L93-96", "source": "transcript"}]</data>
    </edge>
