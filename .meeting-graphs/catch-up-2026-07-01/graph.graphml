      <data key="d59">claim:0018</data>
      <data key="d60">0.7</data>
      <data key="d61">[{"quote": "I mean, I like the stamp, but none of these, to my eye or to my, like, sort of reasoning, are accurate enough. If you think about what we're trying to achieve here, it's just not going to work.", "ts": 1073.1, "source": "transcript"}, {"quote": "I actually had high hopes for this. I thought it was going to be, like, okay, cool. Like, a solid algorithm and solid hashing or, like, those things would be able to detect the similar pages. But I guess it's just not.", "ts": 1307.3, "source": "transcript"}]</data>
    </edge>
    <edge source="claim:0028" target="decision:0002" id="e-supports-0185">
      <data key="d57">SUPPORTS</data>
      <data key="d58">claim:0028</data>
      <data key="d59">decision:0002</data>
      <data key="d60">0.7</data>
      <data key="d61">[{"quote": "But my feeling here is obviously, like I said, like, because of the accuracy issue with what we're working with, I don't, there's just no margin for error, really.", "ts": 1387.0, "source": "transcript"}, {"quote": "We can try it.", "ts": 1336.3, "source": "transcript"}]</data>
    </edge>
