      <data key="d58">claim:0020</data>
      <data key="d59">artifact:salli</data>
      <data key="d60">0.9</data>
      <data key="d61">[{"quote": "Do you know what you've actually done now is you've solved another problem we have, which is duplicate detection in the sorting algorithm for Sally.", "ts": 1104.5, "source": "transcript"}]</data>
    </edge>
