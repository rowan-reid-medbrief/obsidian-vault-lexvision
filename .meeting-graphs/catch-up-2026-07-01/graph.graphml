      <data key="d60">0.9</data>
      <data key="d61">[{"quote": "And it was during that house-sitting that we both discovered that we are a little bit allergic to cats. And Lynn quite a lot allergic to cats.", "ts": "L26-27", "source": "transcript"}]</data>
