      <data key="d58">person:rowan-reid</data>
      <data key="d59">claim:0005</data>
      <data key="d60">0.9</data>
      <data key="d61">[{"quote": "And then I've got a matching engine, which uses different styles of matching to try and figure out what happened to each page.", "ts": "L81", "source": "transcript"}]</data>
    </edge>
    <edge source="person:rowan-reid" target="claim:0006" id="e-asserted-0027">
      <data key="d57">ASSERTED</data>
      <data key="d58">person:rowan-reid</data>
      <data key="d59">claim:0006</data>
      <data key="d60">0.85</data>
      <data key="d61">[{"quote": "Once you know that you've got the page, the right page, it manages to apply them correctly.", "ts": "L86", "source": "transcript"}]</data>
    </edge>
    <edge source="person:rowan-reid" target="claim:0008" id="e-asserted-0029">
