      <data key="d3">[{"quote": "do we do this before cumulus or after cumulus, our nice guideline extraction, so that we could use their pipeline basically. Once they do the handover.", "ts": 1570, "source": "chapter_3"}]</data>
      <data key="d4">["3"]</data>
