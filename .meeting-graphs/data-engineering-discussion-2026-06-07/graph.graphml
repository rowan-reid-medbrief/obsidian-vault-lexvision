    </node>
    <node id="question:0006">
      <data key="d0">Question</data>
      <data key="d1">Is there any additional Cumulus material available beyond the pre-hackathon documentation?</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "Is there any more, I know there's the video from yesterday that we're going to request access to. Beyond that, all I've got from Cumulus is I think the documentation that you shared with me, Laura... So is there anything more to share that's useful?", "ts": 1862, "source": "Rowan Reid"}]</data>
