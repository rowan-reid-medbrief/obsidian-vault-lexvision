    <node id="topic:pseudonymization">
      <data key="d0">Topic</data>
      <data key="d1">Clinical Case Pseudonymization</data>
      <data key="d2">0.95</data>
      <data key="d3">[{"quote": "we want to evaluate how they're doing with this pseudonymization because they didn't go into too much detail as to how they're going to solve it", "ts": 560, "source": "chapter_2"}]</data>
      <data key="d4">["2", "3"]</data>
