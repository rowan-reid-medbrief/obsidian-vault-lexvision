      <data key="d44">0.9</data>
      <data key="d45">[{"quote": "we are going to do using, of course, some models for Azure OpenAI or others. We can use any kind of models that are on Foundry. And this is where the magic happens.", "ts": 1620, "source": "transcript"}]</data>
    </edge>
    <edge source="person:joao-margura" target="claim:0009" id="e-0255">
