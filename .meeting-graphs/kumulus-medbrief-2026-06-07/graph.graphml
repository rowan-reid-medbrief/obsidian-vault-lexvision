    <node id="artifact:kumulus-proposal">
      <data key="d0">Artifact</data>
      <data key="d1">Kumulus Proposal (Fixed-Fee PoV / Medical-Legal AI MVP)</data>
      <data key="d2">0.95</data>
      <data key="d11">proposal-document</data>
      <data key="d12">slide deck</data>
      <data key="d7">["chapter:01", "chapter:02", "chapter:03", "chapter:04", "chapter:05"]</data>
      <data key="d9">[{"quote": "Today, John will walk you through the proposal. So it's really important we use this moment to see if you have any question, if we need to review or changing something.", "ts": 2, "source": "transcript"}, {"quote": "So we are proposing to select one domain... we are proposing gathering one medical domain... This is a fixed fee proposal.", "ts": 58, "source": "transcript"}]</data>
    </node>
    <node id="artifact:engagement-scope-slide">
      <data key="d0">Artifact</data>
      <data key="d1">Engagement Scope Slide (In-Scope / Out-of-Scope)</data>
      <data key="d2">0.95</data>
      <data key="d11">slide</data>
      <data key="d7">["chapter:03"]</data>
      <data key="d9">[{"quote": "ENGAGEMENT SCOPE\nPoV Focus: Feasibility of for one surgery case selected by Medbrief, NICE guideline ingestion, extracting/pseudonymizing sensitive entities, and case-guideline comparison.\nIN SCOPE\nOne medical domain: ex. hernia surgery.\nOne current and one 2020 NICE guideline version.\nOne or two real case examples.\nExisting OCR using Document Intelligence.\nEntity extraction and identity resolution.\nDeterministic pseudonymization.\nInitial case vs guideline comparison.\nEvidence-backed outputs for review.\nOUT OF SCOPE\nHandwritten medical notes.\nFull historical NICE processing.\nFull production application development.\nGraphQL or custom API layer development.\nDICOM and radiology processing.", "ts": 293, "source": "frames:chapframe-03.png"}]</data>
    </node>
    <node id="artifact:pain-points-slide">
      <data key="d0">Artifact</data>
      <data key="d1">Current Environment and Pain Points Slide</data>
      <data key="d2">0.95</data>
      <data key="d11">slide</data>
      <data key="d7">["chapter:02"]</data>
      <data key="d9">[{"quote": "CURRENT ENVIRONMENT &amp; PAIN POINTS\nMedbrief is building a platform to support medical-legal case intelligence by comparing patient case documentation against NICE medical guidelines. Today, this is a highly manual process involving legal and clinical review of large volumes of PDF documentation, requiring complex interpretation and evidence review.\nKEY CHALLENGES\nLarge volumes of unstructured medical-legal PDF documentation.\nManual comparison between case documentation and NICE guidelines.\nNeed to identify correct historical NICE versions based on case dates.\nSensitive medical and personal information risks.\nEntity ambiguity across patients, doctors, hospitals, and documents.\nOCR limitations and inconsistent document quality.\nNeed for explainable, auditable, and defensible outputs.", "ts": 42, "source": "frames:frame-00006.png"}]</data>
    </node>
    <node id="artifact:nice-api">
      <data key="d0">Artifact</data>
      <data key="d1">NICE API</data>
      <data key="d2">0.9</data>
      <data key="d11">external-api</data>
      <data key="d13">org:nice</data>
      <data key="d7">["chapter:04", "chapter:05"]</data>
      <data key="d9">[{"quote": "are you also keeping in scope the connection through the API to nice guidelines?", "ts": 792, "source": "transcript"}, {"quote": "Primary Access: NICE API. Medbrief leads access, Kumulus supports technical validation.", "ts": 1025, "source": "frames"}]</data>
    </node>
    <node id="artifact:document-intelligence-ocr">
      <data key="d0">Artifact</data>
      <data key="d1">Azure Document Intelligence (OCR Pipeline)</data>
      <data key="d2">0.9</data>
      <data key="d11">azure-service</data>
      <data key="d13">org:medbrief</data>
      <data key="d7">["chapter:04", "chapter:05"]</data>
      <data key="d9">[{"quote": "we will be giving you as input the OCR already that we have from document intelligence", "ts": 617, "source": "transcript"}, {"quote": "Existing OCR using Document Intelligence.", "ts": 293, "source": "frames"}]</data>
    </node>
