      <data key="d42">person:joao-margura</data>
      <data key="d43">claim:0009</data>
      <data key="d44">0.9</data>
      <data key="d45">[{"quote": "Databricks is the best to win the market for doing parallel processing using Spark, so if you want a solution that's fast and reliable. That's Databricks.", "ts": 1992, "source": "transcript"}]</data>
    </edge>
