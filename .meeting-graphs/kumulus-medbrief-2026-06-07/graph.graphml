      <data key="d44">0.8</data>
      <data key="d45">[{"quote": "Databricks is the best to win the market for doing parallel processing using Spark, so if you want a solution that's fast and reliable. That's Databricks.", "ts": 1992, "source": "transcript"}, {"quote": "A 100%, 100% open for the review. The only service here that I really see the necessity for the production grade is Databricks.", "ts": 3187, "source": "transcript"}]</data>
