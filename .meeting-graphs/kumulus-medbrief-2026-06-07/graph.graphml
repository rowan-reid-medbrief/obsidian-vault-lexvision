      <data key="d6">SPEAKER_06</data>
      <data key="d7">["chapter:03", "chapter:04", "chapter:05", "chapter:06", "chapter:08", "chapter:09", "chapter:10", "chapter:11", "chapter:12"]</data>
      <data key="d9">[{"quote": "All right, Laura. Yep.", "ts": 88, "source": "transcript"}, {"quote": "Yes, I have a question. So when you say that one current and one 2029 guideline version, so normally we can have one case will refer to several guidelines.", "ts": 89, "source": "transcript"}, {"quote": "Brendan Hughes, Laura Gongas, Mediha Zukic, Deon Kuhn, Namrata Tanwani, Vanessa Patrocinio, Momoko Iwagami, João (John) Marçura", "ts": 2, "source": "frames:frame-00001.png"}, {"quote": "Sure, Laura. SPEAKER_06: No, I'll leave you going to the details", "ts": 446, "source": "transcript"}, {"quote": "can I ask another question, sorry, about when you mentioned the deterministic pseudonymization, what exactly do you mean by that?", "ts": 1250, "source": "transcript"}, {"quote": "So are you comfortable with that, Laura, Tim, Brandon, with this success criteria?", "ts": 2665, "source": "transcript"}]</data>
    </node>
