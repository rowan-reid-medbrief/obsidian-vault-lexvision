    <node id="artifact:data-flow-diagram">
      <data key="d0">Artifact</data>
      <data key="d1">Data Flow Diagram (Sources to Outcome)</data>
      <data key="d2">0.9</data>
      <data key="d11">diagram</data>
      <data key="d7">["chapter:07"]</data>
      <data key="d9">[{"quote": "DATA FLOW DIAGRAM\nSOURCES &gt; ORCHESTRATION &gt; PROCESSING &gt; ENGINE &gt; OUTCOME\nNICE API | Data Factory Movement &amp; Triggers | Databricks Entity Resolution Pseudonymisation | Case vs Guideline Comparison AI Reasoning | Evidence-Backed Assessment Explainable Output", "ts": 2034, "source": "frames.json", "frame": "chapframe-07.png"}]</data>
    </node>
    <node id="artifact:case-guideline-comparison-logic-slide">
      <data key="d0">Artifact</data>
      <data key="d1">Case vs NICE Guideline Logic Slide (5-step process)</data>
      <data key="d2">0.9</data>
      <data key="d11">slide</data>
      <data key="d7">["chapter:08"]</data>
      <data key="d9">[{"quote": "CASE VS NICE GUIDELINE LOGIC\n1. IDENTIFY CONTEXT\n2. SELECT VERSION\n3. EXTRACT FACTS\n4. COMPARE\n5. OUTPUT", "ts": 2293, "source": "frames.json", "frame": "chapframe-08.png"}]</data>
    </node>
    <node id="artifact:step5-comparison-example-slide">
      <data key="d0">Artifact</data>
      <data key="d1">Step 5: Case vs NICE Guideline Comparison Example Slide</data>
      <data key="d2">0.9</data>
      <data key="d11">slide</data>
      <data key="d7">["chapter:06"]</data>
      <data key="d9">[{"quote": "STEP 5: CASE VS NICE GUIDELINE COMPARISON\nLogic &amp; Reasoning\nNICE GUIDELINE (2020) \"Recommended surgical intervention for inguinal hernia in adults is...\"\nVS\nPATIENT CASE FACTS \"Surgery performed on 15/06/2020 using technique X...\"\nASSESSMENT RESULT: ALIGNED / DEVIATED\n(Evidence: Case_Doc_01, Page 4)", "ts": 1944, "source": "frames.json", "frame": "frame-00015.png"}]</data>
    </node>
