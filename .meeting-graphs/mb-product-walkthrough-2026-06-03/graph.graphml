      <data key="d2">0.95</data>
      <data key="d3">[{"quote": "your view is split into four different views um i'm obviously logged in as a as a made brief super admin so all the matters that i've last viewed are listed here up to 20 then any matters that i've added as a fabric would be listed there any invitations that i recently accepted will be listed here and the renewals show any matter that is due for renewal within the next 30 days", "ts": 44.4, "source": "transcript"}, {"quote": "Viewed | Favourites | Invitations | Renewals", "ts": 3.0, "source": "vision"}]</data>
