      <data key="d4">["chapter:16"]</data>
    </node>
    <node id="claim:0074">
      <data key="d0">Claim</data>
      <data key="d1">Suppressed invitation creates folder but defers sending the invitation email</data>
      <data key="d2">0.95</data>
      <data key="d20">A suppressed invitation creates the expert's folder immediately but does not send the invitation email. Once the folder is prepared with the required documents, the fee earner goes to the Users page and sends the invitation from there.</data>
      <data key="d21">person:chantel-van-wyk</data>
      <data key="d22">[]</data>
      <data key="d23">fact</data>
