    <node id="claim:0049">
      <data key="d0">Claim</data>
      <data key="d1">Chronology and Schedule of Radiology are combined when both are selected</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "this one is combined because i selected both services but if the if the clients had selected only chronology then it will only be chronology um and or if they selected only a schedule of radiology it will be only scheduled for radiology but because i selected both they combined", "ts": 1992.6, "source": "transcript"}]</data>
      <data key="d4">["chapter:12"]</data>
