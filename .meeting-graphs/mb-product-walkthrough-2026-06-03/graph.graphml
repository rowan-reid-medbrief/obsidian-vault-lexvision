      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "the matter manager needs to be selected and the the people that will display here is are all the administrators that once again are added at a client level so we've got client users so anyone that has a administrative role yeah so an administrative could be just admin or super admin for clients they'll be listed here and i can select one there", "ts": 774.1, "source": "transcript"}]</data>
      <data key="d4">["chapter:05"]</data>
