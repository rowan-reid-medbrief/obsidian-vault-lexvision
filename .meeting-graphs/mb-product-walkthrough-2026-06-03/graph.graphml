    <node id="claim:0048">
      <data key="d0">Claim</data>
      <data key="d1">If only hosting-only conditions apply, a hosting-only service option is created</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "if there were no records requests and no radiology or any any sorting session then the only service option that would be created here is a hosting only service option so that the users still get or the clients will get bought for hosting only", "ts": 1956.6, "source": "transcript"}]</data>
      <data key="d4">["chapter:12"]</data>
