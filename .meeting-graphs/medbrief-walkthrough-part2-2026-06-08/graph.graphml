      <data key="d3">[{"quote": "if a user logs in incorrectly a certain amount of times, we blacklist. It would be blocked in from logging in for 15 minutes.", "ts": 6374, "source": "transcript"}, {"quote": "You can clear it by just deleting it.", "ts": 6393, "source": "transcript"}]</data>
      <data key="d4">["chapter:20"]</data>
    </node>
    <node id="claim:0087">
      <data key="d0">Claim</data>
