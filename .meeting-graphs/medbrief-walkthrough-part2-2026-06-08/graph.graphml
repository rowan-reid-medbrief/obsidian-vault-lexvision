      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "Annotations, obviously, is just the ability to add any text, notes, underlines, whatever, any formatting that is helpful for the user.", "ts": 796.6, "source": "transcript"}, {"quote": "annotations the moment a client applies annotations, especially to a sorted set of records, if that sorted set of records get updated, those annotations that they make is lost.", "ts": 815.4, "source": "transcript"}]</data>
      <data key="d4">["chapter:03"]</data>
