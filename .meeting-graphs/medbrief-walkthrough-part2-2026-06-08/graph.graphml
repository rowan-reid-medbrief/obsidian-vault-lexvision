      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "whenever a solicitor contacts an expert via made brief match, they are not aware of what that particular expert's email address is in any way. We don't show it to them in any way.", "ts": 4675, "source": "transcript"}, {"quote": "Even the email that they get copied on that goes to the expert, they don't see us.", "ts": 4686, "source": "transcript"}]</data>
