    <node id="claim:0033">
      <data key="d0">Claim</data>
      <data key="d1">Key events is intentionally less detailed than a paid chronology</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "the key events, the idea there is that it's not as detailed as our existing chronologies for one", "ts": 2159.7, "source": "transcript"}, {"quote": "it's literally a text summary. It's got a heading and then it's got a bit of a blurb that describes it, but that's it.", "ts": 2270.0, "source": "transcript"}]</data>
      <data key="d4">["chapter:08"]</data>
      <data key="d20">The key events feature is intentionally less detailed than a paid MedBrief chronology: it is a text summary with a heading and short description, without verbatim copy or specific references.</data>
