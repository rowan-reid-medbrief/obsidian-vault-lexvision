    <node id="topic:computerised-electronic-records">
      <data key="d0">Topic</data>
      <data key="d1">Computerised electronic records (CER): length, bookmarks and classification challenges</data>
      <data key="d2">0.95</data>
      <data key="d3">[{"quote": "some computerized electronic records, especially, and you know what those are, right? Those very long documents that can be very long from, from 50 pages up to like 23,000 pages.", "ts": 531.4, "source": "transcript"}, {"quote": "the computerized records are, they're extremely difficult to, to ingest or congest, to, yeah, to digest", "ts": 680.3, "source": "transcript"}]</data>
      <data key="d4">["chapter:03"]</data>
      <data key="d12">theme</data>
      <data key="d13">0.9</data>
      <data key="d14">["CER", "computerised electronic records", "bookmarks", "Epic", "Oracle", "headings", "classification"]</data>
    </node>
    <node id="topic:cer-classification-limitation">
      <data key="d0">Topic</data>
      <data key="d1">Why MedBrief does not classify or date CER sections in DocSorter</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "any computerized electronic records, when it goes into docs sort of, we don't do anything with it. We just classify it as a computerized electronic record. We do not date it.", "ts": 726.6, "source": "transcript"}, {"quote": "on one page, you might get three or four different clinical sections on one page. Now, for us to, to go through every single page and split it up, you know, cut it and paste it, it will just be, it would just take our sorters very, very long", "ts": 707.7, "source": "transcript"}]</data>
      <data key="d4">["chapter:03"]</data>
      <data key="d12">subtopic</data>
      <data key="d15">topic:computerised-electronic-records</data>
      <data key="d13">0.8</data>
      <data key="d14">["classification", "DocSorter", "sorters", "CER", "date", "limitation"]</data>
    </node>
