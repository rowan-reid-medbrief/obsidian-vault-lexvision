      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "if a user's invitation is suppressed, we obviously can't send them a notification because they haven't, they don't have access to this, to this page yet.", "ts": 370.1, "source": "transcript"}, {"quote": "what the option that will appear there is to not send the notification, but to instead send the invitation.", "ts": 393.7, "source": "transcript"}]</data>
