      <data key="d28">tentative</data>
      <data key="d25">3263.3</data>
    </node>
    <node id="decision:0010">
      <data key="d0">Decision</data>
      <data key="d1">Letter of Approach PDF delivered encrypted via platform login, not as email attachment</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "the letter of approach PDF is generated, but it's not sent as an attachment in the email. The expert must, they must log on to, to view, view it. The reason for that is because it needs to be encrypted, the PDF.", "ts": 3958, "source": "transcript"}]</data>
      <data key="d4">["chapter:13"]</data>
