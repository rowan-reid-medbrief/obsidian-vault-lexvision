    <node id="topic:unsorted-records-duplication">
      <data key="d0">Topic</data>
      <data key="d1">Unsorted records folder and client-upload duplication problem</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "it creates a bit of duplication because if it is a matter that requires a sorting session, they, and the clients has uploaded their own records, they uploaded to this folder", "ts": 253.4, "source": "transcript"}, {"quote": "the ops team, they need to go download whatever the clients uploaded from this folder, go back to the Matter dashboard", "ts": 267.9, "source": "transcript"}]</data>
      <data key="d4">["chapter:02"]</data>
