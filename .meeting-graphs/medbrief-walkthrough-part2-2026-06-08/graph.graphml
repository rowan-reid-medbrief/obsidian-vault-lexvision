    <node id="claim:0007">
      <data key="d0">Claim</data>
      <data key="d1">CER documents can range from 50 to 23,000 pages</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "Those very long documents that can be very long from, from 50 pages up to like 23,000 pages.", "ts": 538.0, "source": "transcript"}]</data>
      <data key="d4">["chapter:03"]</data>
      <data key="d20">Computerised electronic record documents handled by MedBrief can range from 50 pages up to approximately 23,000 pages.</data>
      <data key="d21">person:chantel-van-wyk</data>
      <data key="d22">[]</data>
      <data key="d23">fact</data>
