    <node id="decision:0002">
      <data key="d0">Decision</data>
      <data key="d1">Folders in Case Documentation to be grouped by user type (internal, client, expert)</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "we're going to be grouping the users to internal, you know, by internal users and client users and expert users. So that it's easier to, to identify the different folders.", "ts": 119.4, "source": "transcript"}, {"quote": "that still needs all of that functionality still needs to be implemented. It's taken, it's been parked.", "ts": 150.3, "source": "transcript"}]</data>
