      <data key="d2">0.95</data>
      <data key="d3">[{"quote": "only matters that have got sufficient information, we can use MedBeatMatch on.", "ts": 3648, "source": "transcript"}, {"quote": "at the moment, if it doesn't have sufficient information, we actually disable MedBriefMatch. MedBriefMatch. They'll see the page.", "ts": 3751, "source": "transcript"}]</data>
