      <data key="d3">[{"quote": "if it's got the bookmarks, then we're going to extract the bookmarks. If it doesn't, then we need to, they're using a visual language model, a BLM, to extract the headings.", "ts": 1208.9, "source": "transcript"}]</data>
      <data key="d4">["chapter:05"]</data>
