      <data key="d2">0.95</data>
      <data key="d3">[{"quote": "So when the expert log in, they don't actually see the root private folders. All they see is their name.", "ts": 56.0, "source": "transcript"}, {"quote": "Clients don't see internal folders. So they don't see any of the MedBrief internal folders.", "ts": 93.9, "source": "transcript"}]</data>
