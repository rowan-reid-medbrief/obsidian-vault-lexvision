      <data key="d3">[{"quote": "they'd only be able to interrogate MedWeb sorted records. So in other words, it would have to be sorted records that's within the records parent folder.", "ts": 970.2, "source": "transcript"}]</data>
      <data key="d4">["chapter:04"]</data>
