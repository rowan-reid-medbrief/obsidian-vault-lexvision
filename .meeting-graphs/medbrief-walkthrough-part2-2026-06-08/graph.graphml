      <data key="d2">0.95</data>
      <data key="d3">[{"quote": "So the records page.", "ts": 11.2, "source": "transcript"}, {"quote": "So private folders is most the private folders root folder.", "ts": 46.3, "source": "transcript"}, {"quote": "The second mode is the CRCER index.", "ts": 1175.7, "source": "transcript"}, {"quote": "So we're going to be extracting the headings as well.", "ts": 1200.9, "source": "transcript"}, {"quote": "Then the one thing you also wanted to see was the early case assessment wizard.", "ts": 2328.0, "source": "transcript"}, {"quote": "We changed it from Orthanc to Medream.", "ts": 2565.7, "source": "transcript"}, {"quote": "So I want to show you quickly.", "ts": 4168, "source": "transcript"}, {"quote": "So if you're on the users page or anywhere where there is a user, just, you know, click on the more menu and you can simulate them.", "ts": 4194, "source": "transcript"}, {"quote": "The next one is disclosures.", "ts": 5184, "source": "transcript"}, {"quote": "Chantel van Wyk", "ts": 2, "source": "vision"}]</data>
      <data key="d4">["chapter:01", "chapter:02", "chapter:03", "chapter:04", "chapter:05", "chapter:06", "chapter:07", "chapter:08", "chapter:09", "chapter:10", "chapter:11", "chapter:12", "chapter:13", "chapter:14", "chapter:15", "chapter:16", "chapter:17", "chapter:18", "chapter:19", "chapter:20"]</data>
