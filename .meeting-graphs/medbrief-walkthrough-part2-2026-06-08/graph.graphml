    <node id="person:rowan-reid">
      <data key="d0">Person</data>
      <data key="d1">Rowan Reid</data>
      <data key="d2">0.95</data>
      <data key="d3">[{"quote": "We were still on the records page.", "ts": 13.7, "source": "transcript"}, {"quote": "Yeah, you went through, everybody gets their kind of own private folder.", "ts": 22.5, "source": "transcript"}, {"quote": "The headings, not the bookmarks.", "ts": 1206.3, "source": "transcript"}, {"quote": "So basically find the headings that have content beneath that heading", "ts": 1345.1, "source": "transcript"}, {"quote": "So that early case assessment on the dashboard there had like a progress thing.", "ts": 2459.6, "source": "transcript"}, {"quote": "Do you know why we moved from Orthanc onto, what was it called?", "ts": 2617.3, "source": "transcript"}, {"quote": "Is, is, I mean, I imagine it would still be technically possible for, even if you had matters that didn't have any of those things", "ts": 3718, "source": "transcript"}, {"quote": "So does the whole process end to end, like the searching for them, sending the letter of approach, does this all happen within MedBrief?", "ts": 4145, "source": "transcript"}, {"quote": "So does that mean, so does that come in, is there somebody then at MedBrief who handles these disclosures?", "ts": 5372, "source": "transcript"}, {"quote": "Rowan Reid", "ts": 2, "source": "vision"}]</data>
      <data key="d4">["chapter:01", "chapter:02", "chapter:03", "chapter:04", "chapter:05", "chapter:06", "chapter:07", "chapter:08", "chapter:09", "chapter:10", "chapter:11", "chapter:12", "chapter:13", "chapter:14", "chapter:15", "chapter:16", "chapter:17", "chapter:18", "chapter:19", "chapter:20"]</data>
      <data key="d5">Rowan Reid</data>
      <data key="d6">Rowan Reid</data>
      <data key="d7">[]</data>
      <data key="d8">Newly-joined developer</data>
      <data key="d9">MedBrief</data>
      <data key="d10">True</data>
