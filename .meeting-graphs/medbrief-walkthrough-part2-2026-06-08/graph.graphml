    <node id="claim:0072">
      <data key="d0">Claim</data>
      <data key="d1">Invite suggestions on the users page only show experts who had prior dealings with that specific client</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "a user only come up if it's found, if that user, or in this case, the expert had previous dealings with this particular client in the past.", "ts": 5009, "source": "transcript"}]</data>
      <data key="d4">["chapter:16"]</data>
