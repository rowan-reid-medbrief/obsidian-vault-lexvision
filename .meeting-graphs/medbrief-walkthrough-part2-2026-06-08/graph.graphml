      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "the markup that they ask is really substantial. We're talking about anything between 20 to 45% markup. So, and that would be on top of the expert's fee.", "ts": 2978.9, "source": "transcript"}, {"quote": "we're thinking of only asking 8.5% of the expert's total fee. But we might be changing that a little bit higher, 14.5%.", "ts": 2997.4, "source": "transcript"}]</data>
      <data key="d4">["chapter:11"]</data>
