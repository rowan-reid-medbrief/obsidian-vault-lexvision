      <data key="d2">0.95</data>
      <data key="d3">[{"quote": "personal folders get created in both the case documentation, as well as the private folders, parent folders or root folders.", "ts": 36.5, "source": "transcript"}, {"quote": "the unsorted records, which I said that any records that clients upload, they get uploaded here.", "ts": 241.4, "source": "transcript"}]</data>
