      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "we're also going to be applying the same color to MedBreat Insights. Not as much though, not as drastic as what we're doing here, but at least for the button to stand out, as well as the logo that we're using, just bringing a little bit of the purple as well, because we want to tie in all the AI type peaches with this particular color palette.", "ts": 3117.9, "source": "transcript"}]</data>
