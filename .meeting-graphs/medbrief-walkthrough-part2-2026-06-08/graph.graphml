    <node id="question:0007">
      <data key="d0">Question</data>
      <data key="d1">What sections appear in a CER beyond the patient and repeatable event sections?</data>
      <data key="d2">0.9</data>
      <data key="d3">[{"quote": "So the CER output there, you had a patient section, and then you have like a repeatable event section. And then are there other types of sections as well?", "ts": 1505.3, "source": "transcript"}]</data>
      <data key="d4">["chapter:05"]</data>
